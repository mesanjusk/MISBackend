const { google } = require("googleapis");
const GoogleDriveToken = require("../repositories/googleDriveToken");

const SCOPES = ["https://www.googleapis.com/auth/drive"];

function sanitizeFileName(value = "") {
  return String(value)
    .replace(/[\\/:*?"<>|#%{}~&]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function getOAuthClient() {
  const clientId = process.env.GOOGLE_CLIENT_ID;
  const clientSecret = process.env.GOOGLE_CLIENT_SECRET;
  const redirectUri = process.env.GOOGLE_REDIRECT_URI;

  if (!clientId || !clientSecret || !redirectUri) {
    throw new Error("Missing Google OAuth env configuration");
  }

  return new google.auth.OAuth2(clientId, clientSecret, redirectUri);
}

function getGoogleDriveAuthUrl(returnTo = "") {
  const oauth2Client = getOAuthClient();

  return oauth2Client.generateAuthUrl({
    access_type: "offline",
    prompt: "consent",
    scope: SCOPES,
    state: returnTo || "",
  });
}

async function saveGoogleTokensFromCode(code) {
  const oauth2Client = getOAuthClient();

  const { tokens } = await oauth2Client.getToken(code);
  oauth2Client.setCredentials(tokens);

  const oauth2 = google.oauth2({
    auth: oauth2Client,
    version: "v2",
  });

  const userInfo = await oauth2.userinfo.get();

  if (!tokens.refresh_token) {
    const existing = await GoogleDriveToken.findOne({
      provider: "google_drive",
    }).lean();

    if (!existing?.refreshToken) {
      throw new Error("No refresh token received. Reconnect with prompt=consent.");
    }
  }

  const existingToken = await GoogleDriveToken.findOne({
    provider: "google_drive",
  }).lean();

  const refreshToken = tokens.refresh_token || existingToken?.refreshToken;

  await GoogleDriveToken.findOneAndUpdate(
    { provider: "google_drive" },
    {
      provider: "google_drive",
      email: userInfo?.data?.email || null,
      refreshToken,
      accessToken: tokens.access_token || null,
      expiryDate: tokens.expiry_date || null,
    },
    { upsert: true, new: true, setDefaultsOnInsert: true }
  );

  return {
    email: userInfo?.data?.email || null,
    connected: true,
  };
}

async function getAuthorizedDriveClient() {
  const saved = await GoogleDriveToken.findOne({
    provider: "google_drive",
  }).lean();

  if (!saved?.refreshToken) {
    throw new Error("Google Drive is not connected yet");
  }

  const oauth2Client = getOAuthClient();
  oauth2Client.setCredentials({
    refresh_token: saved.refreshToken,
  });

  const refreshed = await oauth2Client.refreshAccessToken();
  const credentials = refreshed?.credentials || oauth2Client.credentials || {};

  await GoogleDriveToken.updateOne(
    { provider: "google_drive" },
    {
      $set: {
        accessToken: credentials.access_token || null,
        expiryDate: credentials.expiry_date || null,
      },
    }
  );

  return google.drive({
    version: "v3",
    auth: oauth2Client,
  });
}

function isDriveAutomationEnabled() {
  return String(process.env.DRIVE_AUTO_COPY_ON_ORDER || "false").toLowerCase() === "true";
}

async function copyOrderTemplateFileOAuth({
  templateFileId,
  targetFolderId,
  orderNumber,
  customerName,
  description,
}) {
  if (!templateFileId) {
    throw new Error("Missing DRIVE_TEMPLATE_FILE_ID");
  }

  const drive = await getAuthorizedDriveClient();

  const safeOrderNo = sanitizeFileName(orderNumber);
  const safeCustomerName = sanitizeFileName(customerName || "Customer");
  const fileName = `${safeOrderNo} - ${safeCustomerName}`;

  const requestBody = {
    name: fileName,
    description: String(description || "").trim(),
  };

  if (targetFolderId) {
    requestBody.parents = [targetFolderId];
  }

  const response = await drive.files.copy({
    fileId: templateFileId,
    supportsAllDrives: true,
    requestBody,
    fields: "id,name,description,parents,webViewLink,webContentLink",
  });

  return response.data;
}

module.exports = {
  getGoogleDriveAuthUrl,
  saveGoogleTokensFromCode,
  getAuthorizedDriveClient,
  copyOrderTemplateFileOAuth,
  isDriveAutomationEnabled,
};