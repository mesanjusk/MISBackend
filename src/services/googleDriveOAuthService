const { google } = require("googleapis");
const GoogleDriveToken = require("../repositories/googleDriveToken");

const SCOPES = ["https://www.googleapis.com/auth/drive"];

function sanitizeFileName(value = "") {
  return String(value)
    .replace(/[\\/:*?"<>|#%{}~&]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function getOAuthClient() {
  const clientId = process.env.GOOGLE_CLIENT_ID;
  const clientSecret = process.env.GOOGLE_CLIENT_SECRET;
  const redirectUri = process.env.GOOGLE_REDIRECT_URI;

  if (!clientId || !clientSecret || !redirectUri) {
    throw new Error("Missing Google OAuth env configuration");
  }

  return new google.auth.OAuth2(clientId, clientSecret, redirectUri);
}

function isDriveAutomationEnabled() {
  return (
    String(process.env.DRIVE_AUTO_COPY_ON_ORDER || "false").toLowerCase() === "true"
  );
}

function getGoogleDriveAuthUrl(returnTo = "") {
  const oauth2Client = getOAuthClient();

  return oauth2Client.generateAuthUrl({
    access_type: "offline",
    prompt: "consent",
    scope: SCOPES,
    state: returnTo || "",
  });
}

async function fetchGoogleAccountEmail(oauth2Client) {
  try {
    const oauth2 = google.oauth2({
      auth: oauth2Client,
      version: "v2",
    });

    const { data } = await oauth2.userinfo.get();
    return data?.email || null;
  } catch (error) {
    console.warn("Unable to fetch Google account email:", error.message);
    return null;
  }
}

async function saveGoogleTokensFromCode(code) {
  const oauth2Client = getOAuthClient();
  const existing = await GoogleDriveToken.findOne({
    provider: "google_drive",
  }).lean();

  const { tokens } = await oauth2Client.getToken(code);

  oauth2Client.setCredentials(tokens);

  const email = await fetchGoogleAccountEmail(oauth2Client);

  const refreshToken = tokens.refresh_token || existing?.refreshToken || null;

  if (!refreshToken) {
    throw new Error("Refresh token not received. Please reconnect with consent.");
  }

  const saved = await GoogleDriveToken.findOneAndUpdate(
    { provider: "google_drive" },
    {
      provider: "google_drive",
      email,
      refreshToken,
      accessToken: tokens.access_token || existing?.accessToken || null,
      expiryDate: tokens.expiry_date || existing?.expiryDate || null,
      scope: tokens.scope || existing?.scope || SCOPES.join(" "),
      tokenType: tokens.token_type || existing?.tokenType || "Bearer",
      updatedAt: new Date(),
    },
    { upsert: true, new: true, setDefaultsOnInsert: true }
  );

  return {
    email: saved?.email || null,
    connected: true,
  };
}

async function getAuthorizedDriveClient() {
  const saved = await GoogleDriveToken.findOne({
    provider: "google_drive",
  });

  if (!saved?.refreshToken) {
    throw new Error("Google Drive is not connected yet");
  }

  const oauth2Client = getOAuthClient();
  oauth2Client.setCredentials({
    refresh_token: saved.refreshToken,
  });

  const { credentials } = await oauth2Client.refreshAccessToken();

  if (credentials?.access_token) {
    saved.accessToken = credentials.access_token;
    saved.expiryDate = credentials.expiry_date || null;
    if (credentials.refresh_token) {
      saved.refreshToken = credentials.refresh_token;
    }
    await saved.save();
  }

  oauth2Client.setCredentials({
    access_token: credentials?.access_token || saved.accessToken,
    refresh_token: saved.refreshToken,
    expiry_date: credentials?.expiry_date || saved.expiryDate || null,
  });

  return google.drive({
    version: "v3",
    auth: oauth2Client,
  });
}

async function copyOrderTemplateFileOAuth({
  templateFileId,
  targetFolderId,
  orderNumber,
  customerName,
  description,
  mobileNumber,
}) {
  if (!templateFileId) {
    throw new Error("Missing DRIVE_TEMPLATE_FILE_ID");
  }

  const drive = await getAuthorizedDriveClient();

  const safeOrderNo = sanitizeFileName(orderNumber || "Order");
  const safeCustomerName = sanitizeFileName(customerName || "Customer");
  const safeDescription = sanitizeFileName(description || "Work");
  const safeMobile = sanitizeFileName(mobileNumber || "0000000000");

  const fileName = `${safeOrderNo} - ${safeCustomerName} - ${safeDescription} - ${safeMobile}.cdr`;

  const requestBody = {
    name: fileName,
    description: String(description || "").trim(),
  };

  if (targetFolderId) {
    requestBody.parents = [targetFolderId];
  }

  const response = await drive.files.copy({
    fileId: templateFileId,
    supportsAllDrives: true,
    requestBody,
    fields: "id,name,description,parents,webViewLink,webContentLink",
  });

  return response.data;
}

module.exports = {
  getGoogleDriveAuthUrl,
  saveGoogleTokensFromCode,
  getAuthorizedDriveClient,
  copyOrderTemplateFileOAuth,
  isDriveAutomationEnabled,
};